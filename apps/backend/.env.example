# Aplicação
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Banco de dados
# OBS: se a 5432 já estiver ocupada por outro Postgres local, suba o container em
# 5433 (docker run ... -p 5433:5432) e troque a porta na URL abaixo para 5433.
DATABASE_URL="postgresql://azit_user:senha_local@localhost:5432/azit_v3"

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=troque-por-string-aleatoria-longa
JWT_EXPIRES_IN=7d

# Asaas
ASAAS_API_URL=https://api-sandbox.asaas.com/v3
ASAAS_API_KEY=
ASAAS_WEBHOOK_SECRET=

# PopHub
POPHUB_WEBHOOK_SECRET=

# Z-API (WhatsApp)
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
