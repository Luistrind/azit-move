// Azit Move V3 — Prisma Schema (Doc 5 v2.0).
// Decisões: cuid() para PKs; Decimal(12,2) para dinheiro (nunca Float); soft delete via deletedAt;
// StatusParcela só com estados ARMAZENÁVEIS (Em aberto/Vence hoje/Vencida são runtime).
// v2.0: originação absorvida (Lead/Simulacao/Oferta/Proposta/...); Acordo ≠ Novação;
//       Ativo com valorVenda; snapshot no ContratoCredito; intermediárias em ItemFatura.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Enums
// ============================================================

enum TipoPessoa {
  PF
  PJ
}

enum StatusTitular {
  ATIVO
  INATIVO
  BLOQUEADO
}

enum StatusConta {
  ATIVA
  SUSPENSA
  ENCERRADA
}

enum TipoAtivo {
  VEICULO
  OUTRO
}

enum StatusAtivo {
  DISPONIVEL
  EM_CONTRATO
  QUITADO
  RECUPERADO
  SINISTRADO
}

enum TipoCombustivel {
  FLEX
  GASOLINA
  ELETRICO
  DIESEL
  HIBRIDO
}

enum OrigemAtivo {
  LOCADORA
  PARTICULAR
  CONCESSIONARIA
}

enum TipoOrigemCapital {
  CAPITAL_PROPRIO
  EMPRESTIMO
  INVESTIDOR_ATIVO
  FUNDO
}

enum StatusOrigemCapital {
  ATIVO
  ENCERRADO
}

enum ModeloInvestimento {
  ATIVO_ESPECIFICO
  FUNDO_COLETIVO
  FUNDO_EXCLUSIVO
}

enum StatusContratoInvestimento {
  ATIVO
  ENCERRADO
}

enum Periodicidade {
  SEMANAL
  QUINZENAL
  MENSAL
}

enum StatusContratoCredito {
  RASCUNHO
  AGUARDANDO_ASSINATURA
  AGUARDANDO_PAGAMENTO_INICIAL
  AGUARDANDO_ENTREGA_VEICULO
  ATIVO
  INADIMPLENTE
  BLOQUEADO
  SUSPENSO
  EM_RECUPERACAO_VEICULO
  CANCELADO
  RESCINDIDO
  LIQUIDADO_POR_NOVACAO
  QUITADO_AGUARDANDO_TRANSFERENCIA
  QUITADO_TRANSFERENCIA_EFETIVADA
}

enum MotivoEncerramento {
  QUITACAO
  RESCISAO
  CANCELAMENTO
}

enum NaturezaProduto {
  RECORRENTE
  PARCELADO
}

// Catálogo de produtos/serviços (Doc 2 §4.8 / §9). Cada produto compõe a cesta de
// um contrato ou — quando `apartado` (ex: seguro) — tem contrato próprio.
model Produto {
  id            String          @id @default(cuid())
  nome          String
  natureza      NaturezaProduto
  credorPadrao  Credor          @default(AZIT)
  apartado      Boolean         @default(false) // exige contrato próprio (jurídico/tributário)
  valorPadrao   Decimal?        @db.Decimal(12, 2)
  periodicidade Periodicidade?
  ancora        Boolean         @default(false) // produto âncora do ContratoCredito (parcelamento do veículo)
  ativo         Boolean         @default(true)

  itensProposta ItemProposta[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("produtos")
}

// Linha do "carrinho" da proposta — produto escolhido (snapshot) antes de formalizar.
// Na formalização vira ItemContratado (cesta) ou contrato apartado (ex: seguro).
model ItemProposta {
  id            String          @id @default(cuid())
  propostaId    String
  produtoId     String?
  nome          String
  natureza      NaturezaProduto
  apartado      Boolean         @default(false)
  credor        Credor          @default(AZIT)
  valor         Decimal         @db.Decimal(12, 2)
  periodicidade Periodicidade?

  proposta Proposta @relation(fields: [propostaId], references: [id])
  produto  Produto? @relation(fields: [produtoId], references: [id])

  createdAt DateTime @default(now())

  @@index([propostaId])
  @@map("itens_proposta")
}

// De onde o item nasceu. Diferencia produtos vendidos de créditos de acordo.
enum OrigemItemContratado {
  VENDA  // produto vendido na originação ou pós-venda (veículo, proteção, crédito avulso)
  ACORDO // crédito gerado por um Acordo (dilui parcelas em atraso; NÃO liquida o contrato)
}

enum Credor {
  AZIT
  INVESTIDOR
  TERCEIRO
}

enum StatusItemContratado {
  ATIVO
  ENCERRADO
  CANCELADO
}

// Apenas estados ARMAZENÁVEIS.
// Em aberto / Vence hoje / Vencida são calculados em runtime — nunca gravados.
enum StatusParcela {
  PAGA
  PAGA_EM_ATRASO
  PAGA_ANTECIPADA
  RENEGOCIADA
  CANCELADA
  ESTORNADA
  SUSPENSA
}

enum StatusFatura {
  ABERTA
  FECHADA
  VENCIDA
  PAGA
  PAGA_EM_ATRASO
  RENEGOCIADA
}

enum TipoItemFatura {
  PRINCIPAL
  INTERMEDIARIA // parcela-balão da entrada parcelada
  SERVICO
  ENCARGO
}

enum StatusRecebivel {
  ESPERADO
  REALIZADO
  RENEGOCIADO
  CANCELADO
}

enum StatusAcordo {
  RASCUNHO // criado, aguardando aprovação pela alçada (Doc 2 §7.9-A)
  AGUARDANDO_ENTRADA // aprovado; cobrança da entrada gerada, aguardando pagamento
  ATIVO
  QUITADO
  CANCELADO
}

// Motor de aprovação unificado (Doc 2 §7.9-A).
enum StatusAprovacao {
  PENDENTE
  APROVADA
  REPROVADA
  CANCELADA
}

enum DecisaoAprovacao {
  APROVADA
  RECOMENDADA // endosso de quem não tem alçada — escala para o nível acima
  REPROVADA
}

enum StatusNovacao {
  RASCUNHO
  ATIVO
  CANCELADO
}

enum StatusReajuste {
  PENDENTE
  APROVADO
  APLICADO
  CANCELADO
}

// ----- Camada de originação -----

enum CanalOrigem {
  OPERADOR_INTERNO
  LANDING_PAGE
  OLX
  WHATSAPP
  INSTAGRAM
  INDICACAO
  OUTRO
}

enum StatusProposta {
  PENDENTE
  EM_ANALISE
  APROVADA
  REPROVADA
  CANCELADA
  EM_FORMALIZACAO
  CONVERTIDA
}

enum ModalidadeContrato {
  ASSINATURA
  COMPRA_PARCELADA
  COMPRA_VISTA
}

enum PapelTitular {
  COMPRADOR_PRINCIPAL
  COMPRADOR_SECUNDARIO
  GARANTIDOR
}

enum TipoDocumentoProposta {
  CNH
  RG
  EXTRATO_BANCARIO
  EXTRATO_APLICATIVO
  MEI_CNPJ
  COMPROVANTE_ATIVIDADE
  COMPROVANTE_ENDERECO
  COMPROVANTE_RENDA
  RELATORIO_BRICK
  ANEXO_ANALISE // embasamento da análise de crédito (consultas, extratos...)
  OUTRO
}

enum ResultadoParecer {
  APROVADO
  APROVADO_COM_RESSALVAS
  REPROVADO
}

enum OrigemCalculoOferta {
  PACOTE_GENERICO
  VALOR_VENDA_ATIVO
}

// Simulação V3 (Doc 2 §4-A.2). EXPIRADA não é persistida — deriva de validaAte (Regra 7).
enum StatusSimulacao {
  RASCUNHO
  CALCULADA
  APRESENTADA
  CONVERTIDA
  CANCELADA
}

enum TipoOferta {
  OFERTA_FIXA
  PADRAO
  PERSONALIZADA
}

enum RoleUsuario {
  DIRETOR
  ADMIN
  APROVADOR
  OPERADOR
  FINANCEIRO
}

// ============================================================
// Modelos — camada do titular
// ============================================================

model Titular {
  id              String        @id @default(cuid())
  nome            String
  tipoPessoa      TipoPessoa
  cpfCnpj         String        @unique
  rg              String?
  estadoCivil     String?
  profissao       String?
  whatsapp        String
  email           String?
  endereco        String?
  bairro          String?
  cidade          String?
  estado          String?
  cep             String?
  asaasCustomerId String?       @unique
  status          StatusTitular @default(ATIVO)

  conta         Conta?
  leads         Lead[]
  simulacoes    Simulacao[]
  propostas     Proposta[]
  vinculosPapel VinculoPapel[]
  documentos    DocumentoProposta[]

  participantesAnalise ParticipanteAnalise[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([cpfCnpj])
  @@index([asaasCustomerId])
  @@map("titulares")
}

// IntervenienteGarantidor REMOVIDO — garantidor agora é PapelTitular via VinculoPapel.

model Conta {
  id           String      @id @default(cuid())
  titularId    String      @unique
  dataAbertura DateTime    @default(now())
  status       StatusConta @default(ATIVA)

  titular               Titular                @relation(fields: [titularId], references: [id])
  contratosCredito      ContratoCredito[]
  contratosInvestimento ContratoInvestimento[]
  faturas               Fatura[]
  acordos               Acordo[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("contas")
}

// ============================================================
// Modelos — camada de originação (Bloco 7; só estrutura, lógica é dos blocos)
// ============================================================

model Lead {
  id             String      @id @default(cuid())
  nome           String
  cpf            String
  telefone       String? // fase 1 do atendimento (Doc 2 §4-A.1)
  dataNascimento DateTime?
  canalOrigem    CanalOrigem @default(OPERADOR_INTERNO)
  titularId      String?

  titular    Titular?    @relation(fields: [titularId], references: [id])
  simulacoes Simulacao[]

  createdAt DateTime @default(now())

  @@index([cpf])
  @@index([titularId])
  @@map("leads")
}

// Simulação V3 (Doc 2 §4-A.2, Decisão 2026-07-05): porta de entrada comercial.
// Cálculo no backend, parâmetros VERSIONADOS, prazo em MESES com frequência.
// Ativo opcional (valor à vista manual). EXPIRADA é derivada de validaAte (Regra 7).
model Simulacao {
  id                String          @id @default(cuid())
  leadId            String?
  titularId         String?
  ativoId           String? // opcional: simulação por valor manual
  valorAvista       Decimal?        @db.Decimal(12, 2) // base comercial (VA)
  valorAvistaManual Boolean         @default(false) // origem: manual × cadastro do ativo
  valorEntrada      Decimal         @db.Decimal(12, 2)
  prazoSemanas      Int? // LEGADO (simulações V1/V2)
  prazoMeses        Int? // V3: 6–48 meses (parâmetros)
  periodicidade     Periodicidade   @default(SEMANAL) // frequência da parcela final (V3)
  status            StatusSimulacao @default(RASCUNHO)
  validaAte         DateTime? // conversão de expirada exige recálculo
  parametroVersaoId String? // versão dos parâmetros usada no cálculo (rastreabilidade)
  observacoes       String?

  lead            Lead?                      @relation(fields: [leadId], references: [id])
  titular         Titular?                   @relation(fields: [titularId], references: [id])
  ativo           Ativo?                     @relation(fields: [ativoId], references: [id])
  parametroVersao VersaoParametrosSimulacao? @relation(fields: [parametroVersaoId], references: [id])
  ofertas         Oferta[]
  proposta        Proposta?

  createdAt DateTime @default(now())

  @@index([ativoId])
  @@index([leadId])
  @@index([status])
  @@map("simulacoes")
}

model Oferta {
  id               String              @id @default(cuid())
  simulacaoId      String
  tipo             TipoOferta          @default(PERSONALIZADA) // oferta_fixa | padrao | personalizada
  origemCalculo    OrigemCalculoOferta
  valorEntrada     Decimal             @db.Decimal(12, 2)
  entradaParcelada Boolean             @default(false)
  prazoSemanas     Int? // LEGADO
  prazoMeses       Int? // V3
  frequencia       Periodicidade       @default(SEMANAL)
  valorParcela     Decimal             @db.Decimal(12, 2) // PF gravada — nunca recalculada
  numeroParcelas   Int
  selecionada      Boolean             @default(false)

  simulacao Simulacao @relation(fields: [simulacaoId], references: [id])

  createdAt DateTime @default(now())

  @@index([simulacaoId])
  @@map("ofertas")
}

// Parâmetros do simulador, VERSIONADOS (Doc 2 §4-A.2): nova configuração = nova
// versão (histórico preservado — a simulação referencia a versão usada). Edição
// restrita a ADMIN/DIRETOR e auditada. Valores monetários em REAIS (Decimal).
model VersaoParametrosSimulacao {
  id                 String   @id @default(cuid())
  comissaoInicial    Decimal  @db.Decimal(12, 2) // CI — somada ao valor do parcelamento
  comissaoRecorrente Decimal  @db.Decimal(12, 2) // CR — somada à parcela mensal
  taxaMensal         Decimal  @db.Decimal(8, 6) // TR fração a.m. (0.02 = 2%)
  entradaMinima      Decimal  @db.Decimal(12, 2)
  prazoMinMeses      Int
  prazoMaxMeses      Int
  prazosPadronizados String // ex: "6,12,24,36,48"
  taxaDescontoAntecipacaoCR  Decimal @db.Decimal(8, 6) @default(0.2) // desconto do CR na antecipação (planilha Vicente)
  fatorPrecificacaoSemanal   Decimal @db.Decimal(8, 4) @default(4) // parcela exibida (reunião 11/07)
  fatorPrecificacaoQuinzenal Decimal @db.Decimal(8, 4) @default(2)
  fatorSemanal       Decimal  @db.Decimal(8, 4) // 4.3450 semanas/mês — Nº de parcelas do CONTRATO
  fatorQuinzenal     Decimal  @db.Decimal(8, 4) // 2.1725
  validadeDias       Int      @default(7)
  ofertasPadrao      Json // [{prazoMeses, frequencia, valorEntrada(centavos)}]
  vigenteDesde       DateTime @default(now())
  criadoPor          String?

  simulacoes Simulacao[]

  createdAt DateTime @default(now())

  @@map("versoes_parametros_simulacao")
}

// Oferta fixa (Doc 2 §4-A.3): condição comercial DESENHADA pela Azit (números
// redondos, ex.: "R$ 599/semana"), com ativos vinculados no cadastro. Aparece em
// destaque na simulação quando o ativo selecionado está vinculado.
model OfertaFixa {
  id            String        @id @default(cuid())
  nome          String // ex: "Promoção da semana"
  valorEntrada  Decimal       @db.Decimal(12, 2)
  valorParcela  Decimal       @db.Decimal(12, 2)
  frequencia    Periodicidade @default(SEMANAL)
  prazoMeses    Int
  ativa         Boolean       @default(true)
  vigenciaInicio DateTime?
  vigenciaFim   DateTime? // campanhas "só hoje/esta semana"

  ativos Ativo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ofertas_fixas")
}

// Central de documentos do veículo (Doc 2 §4.4-A): CRLV, nota fiscal, etc.
// Arquivo baixável; dados extraídos podem preencher o cadastro (só campos existentes).
model AtivoDocumento {
  id         String   @id @default(cuid())
  ativoId    String
  tipo       String // crlv | nota_fiscal | laudo | outro
  nome       String // nome original do arquivo
  arquivoRef String // referência no storage
  criadoPor  String?

  ativo Ativo @relation(fields: [ativoId], references: [id])

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([ativoId])
  @@map("ativo_documentos")
}

// Centro de custo do ativo (Doc 2 §4.4-A): lançamentos de CUSTO por veículo
// (manutenção, documentação, franquia...). Receita é calculada em runtime
// (parcelas pagas dos contratos) — Regra 7. Tipo é texto: catálogo aberto.
model LancamentoCustoAtivo {
  id        String   @id @default(cuid())
  ativoId   String
  tipo      String // manutencao | documentacao | seguro | franquia | outro | ...
  descricao String
  valor     Decimal  @db.Decimal(12, 2)
  data      DateTime @default(now())
  criadoPor String?

  ativo Ativo @relation(fields: [ativoId], references: [id])

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([ativoId])
  @@map("lancamentos_custo_ativo")
}

// Log de auditoria (Doc 2 §4-A.2 "Controles de segurança"): ações críticas com
// antes/depois. Nasce na simulação/parâmetros; genérico para outras operações.
model LogAuditoria {
  id         String  @id @default(cuid())
  usuarioId  String?
  acao       String // simulacao_criada | simulacao_convertida | parametros_alterados | ...
  entidade   String // simulacao | versao_parametros | ...
  entidadeId String?
  antes      Json?
  depois     Json?

  createdAt DateTime @default(now())

  @@index([entidade, entidadeId])
  @@index([acao])
  @@map("logs_auditoria")
}

model Proposta {
  id               String             @id @default(cuid())
  simulacaoId      String?            @unique
  titularId        String
  ativoId          String
  modalidade       ModalidadeContrato @default(COMPRA_PARCELADA)
  valorEntrada     Decimal            @db.Decimal(12, 2)
  prazoSemanas     Int
  prazoMeses       Int? // V3: condição da oferta escolhida (prazo em meses)
  frequencia       Periodicidade? // V3: define periodicidade + nº de parcelas do contrato
  valorParcela     Decimal            @db.Decimal(12, 2)
  numeroParcelas   Int
  status           StatusProposta     @default(PENDENTE)
  contratoGeradoId String?            @unique

  simulacao      Simulacao?          @relation(fields: [simulacaoId], references: [id])
  titular        Titular             @relation(fields: [titularId], references: [id])
  ativo          Ativo               @relation(fields: [ativoId], references: [id])
  vinculos       VinculoPapel[]
  documentos     DocumentoProposta[]
  parecer        Parecer?
  analiseCadastro AnaliseCadastro?
  itens          ItemProposta[]
  contratoGerado ContratoCredito?    @relation("PropostaContrato", fields: [contratoGeradoId], references: [id])
  contratosPacote ContratoCredito[]  @relation("PacoteProposta")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([titularId])
  @@index([status])
  @@map("propostas")
}

model VinculoPapel {
  id                String       @id @default(cuid())
  titularId         String
  papel             PapelTitular
  propostaId        String?
  contratoCreditoId String?

  titular         Titular          @relation(fields: [titularId], references: [id])
  proposta        Proposta?        @relation(fields: [propostaId], references: [id])
  contratoCredito ContratoCredito? @relation(fields: [contratoCreditoId], references: [id])

  createdAt DateTime @default(now())

  @@unique([titularId, propostaId])
  @@index([propostaId])
  @@index([contratoCreditoId])
  @@map("vinculos_papel")
}

model DocumentoProposta {
  id         String                @id @default(cuid())
  propostaId String
  titularId  String
  tipo       TipoDocumentoProposta
  arquivoRef String
  dataAnexo  DateTime              @default(now())

  proposta Proposta @relation(fields: [propostaId], references: [id])
  titular  Titular  @relation(fields: [titularId], references: [id])

  @@index([propostaId])
  @@map("documentos_proposta")
}

model Parecer {
  id               String           @id @default(cuid())
  propostaId       String           @unique
  resultado        ResultadoParecer
  motivoReprovacao String?
  motivosRessalva  String? // CSV dos motivos (aprovado com ressalvas — todos exigem garantidor)
  observacao       String? // observação analítica do analista
  exigeGarantidor  Boolean          @default(false)
  analistaId       String?
  data             DateTime         @default(now())

  proposta Proposta @relation(fields: [propostaId], references: [id])

  @@map("pareceres")
}

// ============================================================
// Modelos — camada do ativo e capital
// ============================================================

model Ativo {
  id                   String           @id @default(cuid())
  tipo                 TipoAtivo        @default(VEICULO)
  descricao            String
  marca                String?
  modelo               String?
  anoFabricacao        Int?
  anoModelo            Int?
  cor                  String?
  placa                String?          @unique
  chassi               String?          @unique
  renavam              String?
  origem               OrigemAtivo?
  combustivel          TipoCombustivel?
  quilometragemEntrada Int?
  valorAquisicao       Decimal?         @db.Decimal(12, 2)
  valorVenda           Decimal?         @db.Decimal(12, 2) // base da precificação individualizada
  pacoteOfertaId       String? // vínculo opcional a pacote/oferta genérica (legado PopHub)
  ofertaFixaId         String? // oferta fixa desenhada (Doc 2 §4-A.3) — seletor no cadastro
  status               StatusAtivo      @default(DISPONIVEL)

  origemCapital    OrigemCapital?
  ofertaFixa       OfertaFixa?           @relation(fields: [ofertaFixaId], references: [id])
  lancamentosCusto LancamentoCustoAtivo[]
  documentos       AtivoDocumento[]
  // 1 ativo pode ter vários contratos no tempo (ex: novação gera um novo);
  // a regra "1 ativo = 1 contrato ATIVO" é garantida em runtime (Doc 2 §4.4).
  contratosCredito ContratoCredito[]
  simulacoes       Simulacao[]
  propostas        Proposta[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([chassi])
  @@index([placa])
  @@index([status])
  @@map("ativos")
}

model OrigemCapital {
  id                     String              @id @default(cuid())
  ativoId                String              @unique
  tipo                   TipoOrigemCapital
  contratoInvestimentoId String?
  valorAportado          Decimal             @db.Decimal(12, 2)
  taxaRetorno            Decimal?            @db.Decimal(8, 6)
  dataAporte             DateTime
  status                 StatusOrigemCapital @default(ATIVO)

  ativo                Ativo                 @relation(fields: [ativoId], references: [id])
  contratoInvestimento ContratoInvestimento? @relation(fields: [contratoInvestimentoId], references: [id])
  recebiveis           Recebivel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contratoInvestimentoId])
  @@map("origens_capital")
}

model ContratoInvestimento {
  id                  String                     @id @default(cuid())
  numero              String                     @unique
  contaId             String
  modelo              ModeloInvestimento
  valorAportado       Decimal                    @db.Decimal(12, 2)
  taxaRetorno         Decimal?                   @db.Decimal(8, 6)
  dataAporte          DateTime
  dataInicio          DateTime
  dataVencimento      DateTime?
  capitalAmortizado   Decimal                    @default(0) @db.Decimal(12, 2)
  rendimentoAcumulado Decimal                    @default(0) @db.Decimal(12, 2)
  status              StatusContratoInvestimento @default(ATIVO)

  conta          Conta           @relation(fields: [contaId], references: [id])
  origensCapital OrigemCapital[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([contaId])
  @@index([modelo])
  @@index([status])
  @@map("contratos_investimento")
}

// ============================================================
// Modelos — cobrança e financeiro
// ============================================================

model ContratoCredito {
  id                   String                @id @default(cuid())
  numero               String                @unique
  contaId              String
  ativoId              String
  snapshotJson         Json? // fotografia congelada na formalização (fonte da geração documental)
  snapshotLockedAt     DateTime?
  dataAssinatura       DateTime
  dataPrimeiraParcela  DateTime
  valorTotal           Decimal               @db.Decimal(12, 2)
  valorEntrada         Decimal               @default(0) @db.Decimal(12, 2)
  entradaParcelada     Boolean               @default(false) // entrada dividida em intermediárias (Doc 2 §4-A.3)
  modalidade           ModalidadeContrato    @default(ASSINATURA) // ASSINATURA (veículo) | COMPRA_PARCELADA (crédito de manutenção — Doc 2 §4.7-A)
  assinaturaTitularEm  DateTime? // assinatura mock do titular (Doc 3 §8-A.6)
  assinaturaAzitEm     DateTime? // assinatura mock da Azit
  cronogramaGeradoEm   DateTime? // "dia zero": cronograma nasce no pagamento da entrada (Decisão 2026-06-29)
  saldoDevedor         Decimal               @db.Decimal(12, 2)
  numeroParcelas       Int
  valorParcelaInicial  Decimal               @db.Decimal(12, 2)
  periodicidade        Periodicidade         @default(SEMANAL)
  indiceReajuste       String?
  taxaMultaAtraso      Decimal               @default(2.0) @db.Decimal(5, 2)
  taxaJurosAtraso      Decimal               @default(1.0) @db.Decimal(5, 2)
  taxaDescontoQuitacao Decimal?              @db.Decimal(8, 6)
  status               StatusContratoCredito @default(RASCUNHO)
  solicitadoPor        String? // crédito de manutenção: usuário que originou (Doc 2 §4.7-A)
  aprovadoPor          String? // usuário que aprovou pela alçada (§7.9)
  dataAprovacao        DateTime?
  dataEncerramento     DateTime?
  motivoEncerramento   MotivoEncerramento?
  asaasSubscriptionId  String?
  propostaPacoteId     String? // contrato pertence ao pacote de uma proposta (carrinho)

  conta             Conta            @relation(fields: [contaId], references: [id])
  ativo             Ativo            @relation(fields: [ativoId], references: [id])
  itensContratados  ItemContratado[]
  parcelas          Parcela[]
  recebiveis        Recebivel[]
  acordos           Acordo[]
  reajustes         ReajusteIPCA[]
  vinculosPapel     VinculoPapel[]
  propostaOrigem    Proposta?        @relation("PropostaContrato")
  propostaPacote    Proposta?        @relation("PacoteProposta", fields: [propostaPacoteId], references: [id])
  novacaoComoOrigem Novacao?         @relation("NovacaoOrigem")
  novacaoComoNovo   Novacao?         @relation("NovacaoNovo")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([contaId])
  @@index([ativoId])
  @@index([numero])
  @@index([status])
  @@map("contratos_credito")
}

model ItemContratado {
  id             String               @id @default(cuid())
  contratoId     String
  descricao      String
  natureza       NaturezaProduto
  origem         OrigemItemContratado @default(VENDA)
  acordoOrigemId String? // acordo conta-cêntrico gera um item por contrato (1:N)
  credor         Credor               @default(AZIT)
  credorId       String?
  valor          Decimal              @db.Decimal(12, 2)
  numeroParcelas Int?
  periodicidade  Periodicidade?
  dataInicio     DateTime
  dataFim        DateTime?
  status         StatusItemContratado @default(ATIVO)

  contrato     ContratoCredito @relation(fields: [contratoId], references: [id])
  acordoOrigem Acordo?         @relation("ItemGeradoPorAcordo", fields: [acordoOrigemId], references: [id])
  parcelas     Parcela[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([contratoId])
  @@index([origem])
  @@map("itens_contratados")
}

model Parcela {
  id               String         @id @default(cuid())
  contratoId       String
  itemContratadoId String
  numero           Int
  totalParcelas    Int
  display          String
  valorNominal     Decimal        @db.Decimal(12, 2)
  dataVencimento   DateTime
  dataPagamento    DateTime?
  valorPago        Decimal?       @db.Decimal(12, 2)
  valorEncargo     Decimal?       @db.Decimal(12, 2)
  // status NULL = em aberto/vence hoje/vencida (calculado em runtime pela data)
  status           StatusParcela?
  faturaId         String?
  // acordoId: vínculo das parcelas em atraso COBERTAS por um acordo (não usar
  // status RENEGOCIADA como marca — Doc 2 §4.14). As parcelas NOVAS do acordo
  // pertencem ao ItemContratado de origem ACORDO, não usam este campo.
  acordoId         String?

  contrato        ContratoCredito @relation(fields: [contratoId], references: [id])
  itemContratado  ItemContratado  @relation(fields: [itemContratadoId], references: [id])
  fatura          Fatura?         @relation(fields: [faturaId], references: [id])
  acordoCobertura Acordo?         @relation("ParcelasCobertas", fields: [acordoId], references: [id])
  recebivel       Recebivel?
  itensFatura     ItemFatura[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([contratoId])
  @@index([itemContratadoId])
  @@index([faturaId])
  @@index([dataVencimento])
  @@index([status])
  @@map("parcelas")
}

model Fatura {
  id                String       @id @default(cuid())
  contaId           String
  numero            Int
  periodoReferencia DateTime
  dataFechamento    DateTime
  dataVencimento    DateTime
  dataPagamento     DateTime?
  valorTotal        Decimal      @default(0) @db.Decimal(12, 2)
  valorPago         Decimal?     @db.Decimal(12, 2)
  status            StatusFatura @default(ABERTA)
  asaasChargeId     String?
  acordoId          String?

  conta       Conta        @relation(fields: [contaId], references: [id])
  itensFatura ItemFatura[]
  parcelas    Parcela[]
  acordo      Acordo?      @relation(fields: [acordoId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([contaId])
  @@index([status])
  @@index([dataVencimento])
  @@index([asaasChargeId])
  @@map("faturas")
}

model ItemFatura {
  id        String         @id @default(cuid())
  faturaId  String
  parcelaId String? // opcional: intermediárias e serviços podem não ter parcela
  tipo      TipoItemFatura
  descricao String
  valor     Decimal        @db.Decimal(12, 2)
  credor    Credor         @default(AZIT)
  credorId  String?

  fatura  Fatura   @relation(fields: [faturaId], references: [id])
  parcela Parcela? @relation(fields: [parcelaId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([faturaId])
  @@index([parcelaId])
  @@map("itens_fatura")
}

model Recebivel {
  id                   String          @id @default(cuid())
  contratoId           String
  parcelaId            String          @unique
  origemCapitalId      String
  dataPrevista         DateTime
  valorPrevisto        Decimal         @db.Decimal(12, 2)
  dataRealizada        DateTime?
  valorRealizado       Decimal?        @db.Decimal(12, 2)
  status               StatusRecebivel @default(ESPERADO)
  // Breakdown PLACEHOLDER — fórmula pendente (Sebastião / estrutura do fundo)
  breakdownCapital     Decimal?        @db.Decimal(12, 2)
  breakdownRendimento  Decimal?        @db.Decimal(12, 2)
  breakdownTaxaServico Decimal?        @db.Decimal(12, 2)

  contrato      ContratoCredito @relation(fields: [contratoId], references: [id])
  parcela       Parcela         @relation(fields: [parcelaId], references: [id])
  origemCapital OrigemCapital   @relation(fields: [origemCapitalId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([contratoId])
  @@index([origemCapitalId])
  @@index([status])
  @@index([dataPrevista])
  @@map("recebiveis")
}

// ============================================================
// Modelos — acordo, novação e reajuste
// ============================================================

// Acordo: recuperação BRANDA. Dilui parcelas em atraso; NÃO liquida o contrato.
// Acordo é da CONTA (Doc 2 §7.7, Decisão 2026-07-03): cobre as parcelas em atraso de
// TODOS os contratos do titular. Internamente explode em ItemContratado ACORDO por
// contrato afetado (preserva credor/recebível). contratoId permanece só como legado.
model Acordo {
  id                    String       @id @default(cuid())
  contaId               String
  contratoId            String? // legado (acordos antigos, por contrato)
  operadorId            String
  dataCriacao           DateTime     @default(now())
  dataEfetivacao        DateTime?
  valorTotalRenegociado Decimal      @db.Decimal(12, 2)
  valorEntrada          Decimal      @db.Decimal(12, 2)
  numeroParcelasNovas   Int
  valorParcelaNova      Decimal       @db.Decimal(12, 2)
  periodicidade         Periodicidade @default(SEMANAL) // plano do acordo (conta-cêntrico não herda de contrato)
  asaasChargeIdEntrada  String?
  status                StatusAcordo  @default(RASCUNHO)
  observacao            String?

  conta            Conta            @relation(fields: [contaId], references: [id])
  contrato         ContratoCredito? @relation(fields: [contratoId], references: [id])
  operador         Usuario          @relation(fields: [operadorId], references: [id])
  // Parcelas em atraso cobertas (recebem vínculo de acordo; NÃO status RENEGOCIADA)
  parcelasCobertas Parcela[]        @relation("ParcelasCobertas")
  // Itens de crédito NOVOS gerados por este acordo (origem ACORDO) — um por contrato afetado
  itensGerados     ItemContratado[] @relation("ItemGeradoPorAcordo")
  faturas          Fatura[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([contaId])
  @@index([contratoId])
  @@index([status])
  @@index([operadorId])
  @@map("acordos")
}

// Solicitação de aprovação — motor unificado (Doc 2 §7.9-A). Propor e aprovar são
// atos distintos: qualquer operação sujeita a alçada gera uma solicitação; a decisão
// (com trilha) fica registrada aqui. Efetivação dispara ao completar N aprovações.
model Aprovacao {
  id             String          @id @default(cuid())
  tipoOperacao   String // FK lógica → TipoOperacaoAlcada.chave
  referenciaTipo String // contrato_credito | acordo | reajuste
  referenciaId   String
  titularId      String? // contexto para a central (atraso, contratos, saldo)
  valor          Decimal         @db.Decimal(12, 2)
  resumo         String
  payload        Json? // termos para efetivação tardia (ex: novação)
  solicitanteId  String
  status         StatusAprovacao @default(PENDENTE)

  operacao    TipoOperacaoAlcada @relation(fields: [tipoOperacao], references: [chave])
  solicitante Usuario            @relation("AprovacaoSolicitante", fields: [solicitanteId], references: [id])
  decisoes    AprovacaoDecisao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([referenciaTipo, referenciaId])
  @@index([titularId])
  @@map("aprovacoes")
}

model AprovacaoDecisao {
  id          String           @id @default(cuid())
  aprovacaoId String
  usuarioId   String
  decisao     DecisaoAprovacao
  parecer     String?

  aprovacao Aprovacao @relation(fields: [aprovacaoId], references: [id])
  usuario   Usuario   @relation("DecisaoUsuario", fields: [usuarioId], references: [id])

  createdAt DateTime @default(now())

  @@index([aprovacaoId])
  @@map("aprovacao_decisoes")
}

// Novação: recuperação RADICAL. Liquida o contrato inteiro e gera um novo.
model Novacao {
  id               String        @id @default(cuid())
  contratoOrigemId String        @unique
  contratoNovoId   String        @unique
  operadorId       String
  dataEfetivacao   DateTime?
  saldoLiquidado   Decimal       @db.Decimal(12, 2)
  status           StatusNovacao @default(RASCUNHO)
  observacao       String?

  contratoOrigem ContratoCredito @relation("NovacaoOrigem", fields: [contratoOrigemId], references: [id])
  contratoNovo   ContratoCredito @relation("NovacaoNovo", fields: [contratoNovoId], references: [id])
  operador       Usuario         @relation("NovacaoOperador", fields: [operadorId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([operadorId])
  @@map("novacoes")
}

model ReajusteIPCA {
  id                     String         @id @default(cuid())
  contratoId             String
  dataAniversario        DateTime
  indiceAplicado         Decimal        @db.Decimal(8, 4)
  valorParcelaAnterior   Decimal        @db.Decimal(12, 2)
  valorParcelaNovo       Decimal        @db.Decimal(12, 2)
  status                 StatusReajuste @default(PENDENTE)
  aprovadoPor            String?
  dataAprovacao          DateTime?
  dataAplicacao          DateTime?
  dataNotificacaoCliente DateTime?

  contrato ContratoCredito @relation(fields: [contratoId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contratoId])
  @@index([status])
  @@map("reajustes_ipca")
}

// Catálogo de tipos de operação sujeitos a alçada (Doc 2 §7.9). Configurável pelo
// admin — novos tipos (ex.: outra modalidade de renegociação) entram sem tocar no código.
model TipoOperacaoAlcada {
  id                    String  @id @default(cuid())
  chave                 String  @unique // credito_avulso | acordo | novacao | reajuste | despesa | venda
  nome                  String // rótulo exibido ao admin
  aprovacoesNecessarias Int     @default(1) // princípio dos 4 olhos configurável (Doc 2 §7.9-A)
  ativo                 Boolean @default(true)

  alcadas    Alcada[]
  aprovacoes Aprovacao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tipos_operacao_alcada")
}

// Alçada de aprovação — matriz configurável PER PAPEL × tipo de operação (Doc 2 §7.9,
// Decisão 2026-07-02). O admin edita quanto cada papel aprova em cada operação.
// `ilimitado` dispensa o teto (ex.: DIRETOR). Valores concretos = placeholder do Vicente.
model Alcada {
  id            String      @id @default(cuid())
  papel         RoleUsuario // OPERADOR | APROVADOR | ADMIN | DIRETOR | FINANCEIRO
  tipoOperacao  String // FK lógica para TipoOperacaoAlcada.chave
  limiteMaximo  Decimal     @default(0) @db.Decimal(12, 2)
  ilimitado     Boolean     @default(false)
  ativo         Boolean     @default(true)

  operacao TipoOperacaoAlcada @relation(fields: [tipoOperacao], references: [chave])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([papel, tipoOperacao])
  @@index([tipoOperacao])
  @@map("alcadas")
}

// ============================================================
// Modelos — operação e autenticação
// ============================================================

model Usuario {
  id        String  @id @default(cuid())
  nome      String
  email     String  @unique
  senhaHash String
  ativo     Boolean @default(true)

  roles                 UsuarioRole[]
  acordos               Acordo[]
  novacoes              Novacao[]          @relation("NovacaoOperador")
  refreshTokens         RefreshToken[]
  aprovacoesSolicitadas Aprovacao[]        @relation("AprovacaoSolicitante")
  decisoesAprovacao     AprovacaoDecisao[] @relation("DecisaoUsuario")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([email])
  @@map("usuarios")
}

model UsuarioRole {
  usuarioId String
  role      RoleUsuario

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  createdAt DateTime @default(now())

  @@id([usuarioId, role])
  @@map("usuario_roles")
}

model RefreshToken {
  id        String   @id @default(cuid())
  usuarioId String
  token     String   @unique
  expiraEm  DateTime
  revogado  Boolean  @default(false)

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  createdAt DateTime @default(now())

  @@index([usuarioId])
  @@index([token])
  @@map("refresh_tokens")
}

// ============================================================
// ANALISE DE CADASTRO - Politica v1.0 / Processo v1.1 / Requisitos v0.2
// (doc 02 sec.14). Fase 1: consultas manuais (placeholder funcional).
// ============================================================

enum StatusAnalise {
  ATENDIMENTO_INICIADO
  SIMULACAO_REALIZADA
  CADASTRO_EM_PREENCHIMENTO
  DOCUMENTOS_ENVIADOS
  CONSULTA_INICIAL_REALIZADA
  EM_TRIAGEM_INICIAL
  PENDENTE_DE_COMPLEMENTO
  EM_ANALISE_COMPLEMENTAR
  SCORE_CONSULTADO
  RESTRICOES_CONSULTADAS
  PARECER_EMITIDO
  APROVADO_ALCADA_ANALISTA
  AGUARDANDO_COCAD
  APROVADO_COCAD
  APROVADO_COM_RESSALVAS
  RESSALVA_EM_TRATAMENTO
  PENDENTE_COMPLEMENTO_COCAD
  LIBERADO_PARA_FORMALIZACAO
  NAO_APROVADO
  PROPOSTA_ENCERRADA
}

enum TipoConsultaExterna {
  CAMADA1
  SCORE_QUOD
  RESTRITIVOS
}

enum SituacaoConsulta {
  CONCLUIDA
  FALHA
}

enum SituacaoPendencia {
  ABERTA
  CUMPRIDA
  EXPIRADA
}

enum TipoRessalva {
  AUMENTO_ENTRADA
  REDUCAO_PROPOSTA
  GARANTIDOR
  DOCUMENTO_ADICIONAL
  AJUSTE_CONDICAO
}

enum SituacaoRessalva {
  PENDENTE
  CUMPRIDA
  VALIDADA
  EXPIRADA
}

enum NivelAlertaFraude {
  DUVIDA_DOCUMENTAL
  INDICIO_RELEVANTE
  INDICIO_CONFIRMADO
  RESOLVIDO
}

enum MotivoEncerramentoAnalise {
  NAO_APROVACAO
  DESISTENCIA
  AUSENCIA_RETORNO
  EXPIRACAO
}

// Parametros versionados da analise (Politica sec.31; RF-24). Nova config = nova versao.
model VersaoParametrosAnalise {
  id                           String   @id @default(cuid())
  comprometimentoAlcada        Decimal  @default(0.40) @db.Decimal(6, 4)
  comprometimentoIntermediario Decimal  @default(0.50) @db.Decimal(6, 4)
  scoreQuodMinimo              Int      @default(600)
  restritivoNaoFinanceiroMax   Decimal  @default(500) @db.Decimal(12, 2)
  fatorSemanal                 Decimal  @default(4.345) @db.Decimal(8, 4)
  fatorQuinzenal               Decimal  @default(2.17) @db.Decimal(8, 4)
  validadeConsultaDias         Int      @default(30)
  validadeAprovacaoDiasUteis   Int      @default(10)
  prazoComplementoDiasUteis    Int      @default(3)
  prazoRessalvaDiasUteis       Int      @default(5)
  validadeRessalvaDiasCorridos Int      @default(7)
  textoAutorizacao             String   @default("Confirmo que o cliente autorizou a realizacao das consultas cadastrais necessarias a analise da proposta.")
  versaoAutorizacao            Int      @default(1)
  politicaVersao               String   @default("1.0")
  criadoPor                    String?
  vigenteDesde                 DateTime @default(now())

  analises AnaliseCadastro[]

  createdAt DateTime @default(now())

  @@map("versoes_parametros_analise")
}

model AnaliseCadastro {
  id                         String                     @id @default(cuid())
  propostaId                 String                     @unique
  parametroVersaoId          String
  status                     StatusAnalise              @default(ATENDIMENTO_INICIADO)
  condutorPrincipalTitularId String?
  parcelaMensalEquivalente   Decimal?                   @db.Decimal(12, 2)
  rendaApuradaTotal          Decimal?                   @db.Decimal(12, 2)
  comprometimento            Decimal?                   @db.Decimal(6, 2)
  aprovadaEm                 DateTime?
  aprovadaPor                String?
  liberadaEm                 DateTime?
  liberadaPor                String?
  encerradaEm                DateTime?
  motivoEncerramento         MotivoEncerramentoAnalise?
  codigoNaoAprovacao         String?
  aprovacaoId                String?

  proposta        Proposta                @relation(fields: [propostaId], references: [id])
  parametroVersao VersaoParametrosAnalise @relation(fields: [parametroVersaoId], references: [id])
  participantes   ParticipanteAnalise[]
  autorizacoes    AutorizacaoConsulta[]
  consultas       ConsultaExterna[]
  pendencias      PendenciaAnalise[]
  ressalvas       RessalvaAnalise[]
  alertasFraude   AlertaFraude[]
  transicoes      TransicaoAnalise[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("analises_cadastro")
}

// Dados da analise por participante (RF-02/07/08). Rendas em REAIS, tres campos
// independentes - o sistema nunca deriva um do outro (feedback 22/07 sec.5).
model ParticipanteAnalise {
  id                          String       @id @default(cuid())
  analiseId                   String
  titularId                   String
  papel                       PapelTitular
  rendaDeclarada              Decimal?     @db.Decimal(12, 2)
  rendaPresumida              Decimal?     @db.Decimal(12, 2)
  rendaApurada                Decimal?     @db.Decimal(12, 2)
  rendaParcialmenteComprovada Boolean      @default(false)
  identidadeValidada          Boolean      @default(false)
  cnhValida                   Boolean      @default(false)
  documentoAlternativo        Boolean      @default(false)
  atividadeComprovada         Boolean      @default(false)
  evidenciaAtividade          String?
  processosRelevantes         Boolean      @default(false)
  observacoes                 String?

  analise AnaliseCadastro @relation(fields: [analiseId], references: [id])
  titular Titular         @relation(fields: [titularId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([analiseId, titularId])
  @@map("participantes_analise")
}

// Autorizacao de consulta via WhatsApp (RF-05) - individual por participante.
model AutorizacaoConsulta {
  id           String   @id @default(cuid())
  analiseId    String
  titularId    String
  atendenteId  String
  dataHora     DateTime @default(now())
  texto        String
  canal        String   @default("WHATSAPP")
  versao       Int
  evidenciaRef String?

  analise AnaliseCadastro @relation(fields: [analiseId], references: [id])

  @@unique([analiseId, titularId])
  @@map("autorizacoes_consulta")
}

// Consulta externa (RF-10). Fase 1: registro manual. resultado (Json) normalizado:
// { score?, restritivosFinanceiros?, restritivosNaoFinanceiros?, protestoChequeExecucao?, resumo? }
model ConsultaExterna {
  id            String              @id @default(cuid())
  analiseId     String
  titularId     String
  tipo          TipoConsultaExterna
  fornecedor    String
  protocolo     String?
  dataConsulta  DateTime            @default(now())
  custo         Decimal?            @db.Decimal(12, 2)
  situacao      SituacaoConsulta
  motivoFalha   String?
  tentativas    Int                 @default(1)
  resultado     Json?
  registradaPor String?

  analise AnaliseCadastro @relation(fields: [analiseId], references: [id])

  @@index([analiseId, titularId, tipo])
  @@map("consultas_externas")
}

// Pendencia/complemento (RF-15) - especifica, com prazo e retorno a etapa de origem.
model PendenciaAnalise {
  id           String            @id @default(cuid())
  analiseId    String
  titularId    String?
  codigo       String
  descricao    String
  prazo        DateTime?
  origemStatus StatusAnalise
  situacao     SituacaoPendencia @default(ABERTA)
  resolvidaEm  DateTime?
  resolvidaPor String?
  criadaPor    String?

  analise AnaliseCadastro @relation(fields: [analiseId], references: [id])

  @@index([analiseId, situacao])
  @@map("pendencias_analise")
}

// Ressalva (RF-19) - aprovacao condicionada; bloqueia formalizacao ate validacao.
model RessalvaAnalise {
  id           String           @id @default(cuid())
  analiseId    String
  tipo         TipoRessalva
  condicao     String
  prazo        DateTime?
  situacao     SituacaoRessalva @default(PENDENTE)
  evidenciaRef String?
  cumpridaEm   DateTime?
  validadaPor  String?
  validadaEm   DateTime?
  criadaPor    String?

  analise AnaliseCadastro @relation(fields: [analiseId], references: [id])

  @@index([analiseId, situacao])
  @@map("ressalvas_analise")
}

// Alerta de fraude por nivel (RF-20) - evidencias preservadas.
model AlertaFraude {
  id           String            @id @default(cuid())
  analiseId    String
  titularId    String?
  nivel        NivelAlertaFraude
  descricao    String
  criadoPor    String?
  resolvidoPor String?
  resolvidoEm  DateTime?

  analise AnaliseCadastro @relation(fields: [analiseId], references: [id])

  @@index([analiseId])
  @@map("alertas_fraude")
}

// Historico de transicoes da maquina de estados (RF-14).
model TransicaoAnalise {
  id        String         @id @default(cuid())
  analiseId String
  de        StatusAnalise?
  para      StatusAnalise
  usuarioId String?
  motivo    String?

  analise AnaliseCadastro @relation(fields: [analiseId], references: [id])

  createdAt DateTime @default(now())

  @@index([analiseId])
  @@map("transicoes_analise")
}
