# Copie para deploy/stack.env (NÃO versionado) e preencha com valores reais.
# Depois: set -a; . deploy/stack.env; set +a; docker stack deploy -c deploy/azit-stack.swarm.yml azit

# Senha do Postgres próprio do Azit (invente uma forte).
POSTGRES_PASSWORD=troque_por_uma_senha_forte

# Segredo do JWT (gere: openssl rand -hex 32).
JWT_SECRET=troque_por_um_hex_de_64_chars

# Asaas (sandbox por enquanto).
ASAAS_API_KEY=sua_chave_sandbox_asaas
ASAAS_WEBHOOK_SECRET=um_token_que_voce_escolhe_e_poe_igual_no_painel_asaas
